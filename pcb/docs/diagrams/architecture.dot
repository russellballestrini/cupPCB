// SEW Architecture — print-ready, black ink on white
digraph architecture {
    graph [
        rankdir=TB
        bgcolor=white
        fontname="Helvetica"
        fontsize=10
        splines=ortho
        pad=0.4
        nodesep=0.5
        ranksep=0.6
    ]
    node [
        fontname="Helvetica"
        fontsize=9
        style=filled
        fillcolor=white
        color=black
        penwidth=1
        shape=box
    ]
    edge [
        fontname="Helvetica"
        fontsize=8
        color=black
        fontcolor="#444444"
        penwidth=0.8
    ]

    subgraph cluster_kernel {
        label="KERNEL  (kernel.html — frozen)"
        style=solid
        color=black
        penwidth=2
        fontname="Helvetica-Bold"
        fontsize=9
        fontcolor=black

        manifold  [label="MANIFOLD\nENGINE"]
        heat      [label="HEAT BUFFER\nFloat32Array[1024]" style="filled" fillcolor="#f0f0f0"]
        adjacency [label="ADJACENCY\nGRAPH  G=(V,E)"]
        pcb       [label="PCB\nCONSOLE" style="dashed"]
        renderer  [label="THREE.JS\nRENDERER"]
        agents    [label="AGENTS\nFriend×5"]
        frontier  [label="FRONTIER\nAnthropic API" style="dashed"]
    }

    subgraph cluster_loader {
        label="LOADER  (index.html)"
        style=dashed
        color="#888888"
        fontsize=9
        fontcolor="#888888"

        boot   [label="BOOT\nSEQUENCE" color="#888888" fontcolor="#888888"]
        loader [label="PROGRAM\nLOADER\n<script src>" color="#888888" fontcolor="#888888"]
    }

    subgraph cluster_programs {
        label="PROGRAMS  (programs/*.js)"
        style=solid
        color="#666666"
        fontsize=9
        fontcolor="#666666"

        p1 [label="BUBBLE_SORT"        color="#666666" fontcolor="#666666"]
        p2 [label="REACTION_DIFFUSION" color="#666666" fontcolor="#666666"]
        p3 [label="LORENZ"             color="#666666" fontcolor="#666666"]
        p4 [label="CONWAY_LIFE"        color="#666666" fontcolor="#666666"]
        p5 [label="…9 more"            color="#666666" fontcolor="#666666" style=dashed]
    }

    user [label="USER\ndraw / type" shape=ellipse]

    user      -> manifold  [label="seedPoints"]
    manifold  -> adjacency [label="build"]
    manifold  -> heat      [label="init zeros"]
    adjacency -> heat      [label="diffuse/frame" style=dashed]
    heat      -> renderer  [label="z += h[i]×w"]
    agents    -> heat      [label="+= 8.0/step" style=dashed]
    adjacency -> agents    [label="N(v)" style=dashed]
    user      -> pcb       [label="cmd"]
    pcb       -> frontier  [label="plain text" style=dashed]
    frontier  -> pcb       [label="reply→eval" style=dashed]
    pcb       -> heat      [label="eval JS" style=dashed]
    boot      -> loader
    loader    -> p1
    loader    -> p2
    loader    -> p3
    loader    -> p4
    loader    -> p5
    p1        -> heat      [label="heat[i]+=" style=dashed]
    p2        -> heat      [style=dashed]
    p3        -> heat      [style=dashed]
    p4        -> heat      [style=dashed]
    p5        -> heat      [style=dashed]
    p1        -> pcb       [label="wrap run()" style=dashed]
    renderer  -> user      [label="viewport"]
}
