// SEW Sym²(X) Construction — print-ready, black ink on white
digraph sym2 {
    graph [
        rankdir=TB
        bgcolor=white
        fontname="Helvetica"
        fontsize=10
        pad=0.4
        nodesep=0.5
        ranksep=0.6
    ]
    node [
        fontname="Helvetica"
        fontsize=9
        style=filled
        fillcolor=white
        color=black
        penwidth=1
        shape=box
    ]
    edge [
        fontname="Helvetica"
        fontsize=8
        color=black
        fontcolor="#444444"
        penwidth=0.8
    ]

    subgraph cluster_X {
        label="X  (user-drawn points)"
        style=solid
        color=black
        fontname="Helvetica-Bold"
        fontsize=9

        p0 [label="p₀" shape=circle]
        p1 [label="p₁" shape=circle]
        p2 [label="p₂" shape=circle]
        pn [label="…"  shape=plaintext style=filled fillcolor=white color=white]
    }

    subgraph cluster_sym2 {
        label="Sym²(X)  (unordered pairs)"
        style=solid
        color=black
        fontname="Helvetica-Bold"
        fontsize=9

        s00 [label="{p₀,p₀}  Δ" fillcolor="#e0e0e0" penwidth=1.5]
        s01 [label="{p₀,p₁}"]
        s02 [label="{p₀,p₂}"]
        s11 [label="{p₁,p₁}  Δ" fillcolor="#e0e0e0" penwidth=1.5]
        s12 [label="{p₁,p₂}"]
        s22 [label="{p₂,p₂}  Δ" fillcolor="#e0e0e0" penwidth=1.5]
        sym_note [label="{p₀,p₁} ≡ {p₁,p₀}  (symmetry)" shape=plaintext style=filled fillcolor=white color=white fontsize=8 fontcolor="#666666"]
    }

    subgraph cluster_embed {
        label="R³ Embedding"
        style=solid
        color=black
        fontname="Helvetica-Bold"
        fontsize=9

        e_diag [label="(mid_x, mid_y, 0)\nz = 0  — on base plane\n← seam / degenerate" fillcolor="#e0e0e0" penwidth=1.5]
        e_off  [label="(mid_x, mid_y, |p−q|)\nz = separation distance\n← rises above base plane"]
    }

    seam_note [label="Δ = diagonal locus\n  p = q  →  z = 0\n  rendered as red seam" shape=box style=dashed color="#666666" fontcolor="#666666" fontsize=8]

    p0 -> s00 [label="p=q"]
    p0 -> s01
    p0 -> s02
    p1 -> s01 [style=dashed]
    p1 -> s11 [label="p=q"]
    p1 -> s12
    p2 -> s02 [style=dashed]
    p2 -> s12 [style=dashed]
    p2 -> s22 [label="p=q"]

    s00 -> e_diag [label="z=0"]
    s11 -> e_diag [style=dashed]
    s22 -> e_diag [style=dashed]
    s01 -> e_off  [label="embed"]
    s12 -> e_off  [style=dashed]

    e_diag -> seam_note [style=dashed arrowhead=none]
}
