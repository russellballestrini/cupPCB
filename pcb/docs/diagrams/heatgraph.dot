// SEW Heat Diffusion — print-ready, black ink on white
// 4×4 subgraph with example values, one diffusion step shown
graph heatgraph {
    graph [
        bgcolor=white
        fontname="Helvetica"
        fontsize=10
        pad=0.5
        nodesep=0.6
        ranksep=0.6
        label="HEAT DIFFUSION — one frame step\nh'[i] = ( h[i] + Σ h[N(i)] ) / ( |N(i)| + 1 ) × 0.96"
        labelloc=t
        labeljust=l
        fontsize=10
        fontname="Helvetica-Bold"
    ]
    node [
        fontname="Helvetica"
        fontsize=8
        style=filled
        fillcolor=white
        color=black
        penwidth=1
        shape=circle
        width=0.75
        fixedsize=true
    ]
    edge [
        fontname="Helvetica"
        fontsize=7
        color="#888888"
        penwidth=0.8
    ]

    // cold vertices — light gray fill proportional to heat
    v00 [label="0"   fillcolor=white]
    v01 [label="0"   fillcolor=white]
    v02 [label="0"   fillcolor=white]
    v03 [label="0"   fillcolor=white]

    v10 [label="20"  fillcolor="#dddddd"]
    v11 [label="300" fillcolor="#888888" fontcolor=white penwidth=2]
    v12 [label="80"  fillcolor="#cccccc"]
    v13 [label="10"  fillcolor="#eeeeee"]

    v20 [label="5"   fillcolor=white]
    v21 [label="150" fillcolor="#aaaaaa" fontcolor=white]
    v22 [label="40"  fillcolor="#dddddd"]
    v23 [label="0"   fillcolor=white]

    v30 [label="0"   fillcolor=white]
    v31 [label="30"  fillcolor="#dddddd"]
    v32 [label="10"  fillcolor="#eeeeee"]
    v33 [label="0"   fillcolor=white]

    // grid edges
    v00 -- v01; v01 -- v02; v02 -- v03
    v10 -- v11; v11 -- v12; v12 -- v13
    v20 -- v21; v21 -- v22; v22 -- v23
    v30 -- v31; v31 -- v32; v32 -- v33

    v00 -- v10; v01 -- v11; v02 -- v12; v03 -- v13
    v10 -- v20; v11 -- v21; v12 -- v22; v13 -- v23
    v20 -- v30; v21 -- v31; v22 -- v32; v23 -- v33

    // diagonal (triangulation)
    v00 -- v11; v01 -- v12; v02 -- v13
    v10 -- v21; v11 -- v22; v12 -- v23
    v20 -- v31; v21 -- v32; v22 -- v33

    // diffusion annotation for v11 (hottest)
    calc [
        label="v11 diffusion step:\nN(v11) = {v00,v01,v10,v12,v20,v21}  deg = 6\nh' = (300+0+0+20+80+5+150) / 7 × 0.96\n    = 555 / 7 × 0.96  =  76.1\n← peak spreads to neighbors"
        shape=box style=filled fillcolor=white color=black
        fontsize=8 fontname="Helvetica" width=3.8 fixedsize=false penwidth=0.8
    ]
    v11 -- calc [style=dashed color=black penwidth=0.8 arrowhead=none]

    // injection note
    inject [
        label="Program / agent injection:\nheat[i] += Δ   (additive, runs before diffuse)"
        shape=box style=dashed color="#666666"
        fontsize=8 fontname="Helvetica" fontcolor="#444444"
        width=3.2 fixedsize=false penwidth=0.8
    ]
}
